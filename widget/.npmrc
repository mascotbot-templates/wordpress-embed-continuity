# MascotBot SDK is published to a private registry (not npmjs.com).
# The auth token is your MascotBot API key — inject it via an env var,
# NEVER commit a real token. Locally:  export MASCOT_NPM_TOKEN=mascot_dev_xxx
# In CI: set MASCOT_NPM_TOKEN as a secret.
@mascotbot:registry=https://npm.mascot.bot/
//npm.mascot.bot/:_authToken=${MASCOT_NPM_TOKEN}
