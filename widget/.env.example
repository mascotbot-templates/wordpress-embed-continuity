# ── MascotBot lipsync license key ──────────────────────────────────────
# Browser-safe publishable key passed to <LipsyncProvider>. Get it from
# https://app.mascot.bot/api-keys
#   mascot_dev_…  → localhost / 127.0.0.1 / *.localhost only (no billing)
#   mascot_pub_…  → your allow-listed production domains
# It is inlined into the client bundle (NEXT_PUBLIC_*) — this is safe; the
# key is scoped to your origins. Keep standing third-party keys server-side.
NEXT_PUBLIC_MASCOT_KEY=mascot_dev_xxxxxxxxxxxxxx

# ── ElevenLabs (server-side only) ──────────────────────────────────────
# Used by /api/get-signed-url to mint a single-use Conversational-AI
# signed URL. The standing xi-api-key never reaches the browser.
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxx
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxx

# ── Private npm registry token (for `pnpm install`) ────────────────────
# The SDK is published to https://npm.mascot.bot/ (see .npmrc). Export the
# SAME mascot_ key as the registry auth token before installing:
#   export MASCOT_NPM_TOKEN=mascot_dev_xxxxxxxxxxxxxx
