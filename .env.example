# ============================================================================
# This template is TWO apps. Each has its own .env.example — copy and fill:
#
#   cp widget/.env.example      widget/.env.local        # API keys live here
#   cp demo-site/.env.example   demo-site/.env.local     # widget URL lives here
#
# Keep this file as a pointer. Do not put real keys in the template root —
# the widget app is the only place that reads secrets.
# ============================================================================

# --- Secrets consumed by the widget app (widget/.env.local) ---------------
# Browser-safe MascotBot lipsync key passed to <LipsyncProvider>. Get it
# from https://app.mascot.bot/api-keys
#   mascot_dev_…  → localhost / 127.0.0.1 / *.localhost only (no billing)
#   mascot_pub_…  → your allow-listed production domains
NEXT_PUBLIC_MASCOT_KEY=mascot_dev_xxxxxxxxxxxxxx
# ElevenLabs agent credentials (server-side only): https://elevenlabs.io/agents
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxx
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxx

# --- Demo-site public var (demo-site/.env.local) --------------------------
# URL of the widget deployment. In local dev: http://localhost:3004
# In production: your widget's public URL (e.g. https://widget.yourdomain.com)
NEXT_PUBLIC_WIDGET_URL=http://localhost:3004

# ── Private npm registry token (for `pnpm install`) ────────────────────
# The SDK is published to https://npm.mascot.bot/ (see widget/.npmrc).
# Export the SAME mascot_ key as the registry auth token before installing:
#   export MASCOT_NPM_TOKEN=mascot_dev_xxxxxxxxxxxxxx
